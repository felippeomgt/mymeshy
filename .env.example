# MyMeshy local config — copy to `.env` and adjust. Loaded by the backend
# (see backend/app/config.py). All values are optional; the app runs without it.

# Hard cap on GPU memory, in GB. 6 = use at most half of a 12GB RTX 3060.
# Budgets <= 8 also enable low-VRAM mode (sequential offload, one stage at a
# time) — slower, but the GPU stays responsive. Set 0 for unlimited.
MYMESHY_VRAM_BUDGET_GB=6

# Adapter selection. `auto` prefers the best installed model and falls back to
# mock, so the app always runs. See the README "Adapters" table for options.
MYMESHY_I23D_ADAPTER=auto      # trellis | hunyuan3d | triposr | mock | auto
MYMESHY_T2I_ADAPTER=auto       # sdxl_turbo | mock | auto
MYMESHY_TEXTURE_ADAPTER=auto   # hunyuan_paint | mock | auto

# Use the full Hunyuan3D-2 shape model instead of the lighter 2mini default.
# MYMESHY_HUNYUAN_SHAPE_MODEL=tencent/Hunyuan3D-2

# Path to Blender (for FBX export). Only needed if auto-detection misses it;
# Steam and standard installs are found automatically.
# MYMESHY_BLENDER_PATH=C:\Program Files\Blender Foundation\Blender 4.2\blender.exe
